# Copy this file to .env and customize values for non-local environments.

# Core secrets
JWT_SECRET=replace-with-a-long-random-secret
TRIGGER_API_KEY=replace-with-trigger-api-key
DUB_API_KEY=replace-with-dub-api-key
PAPER_WS_TOKEN=

# Database
DB_LINKS_USER=postgres
DB_LINKS_PASSWORD=replace-with-strong-password
DB_LINKS_NAME=dublinks

# Service/public URLs
PUBLIC_BASE_URL=http://localhost:3000
REDIS_URL=redis://redis:6379

# Runtime controls
TRIGGER_QUEUE_NAME=ai-jobs
TRIGGER_WORKER_CONCURRENCY=5
TRIGGER_READ_RATE_LIMIT=300
TRIGGER_WRITE_RATE_LIMIT=60
DUB_READ_RATE_LIMIT=300
DUB_WRITE_RATE_LIMIT=60
PAPER_RATE_LIMIT=240
COOLIFY_RATE_LIMIT=180
HOPP_RATE_LIMIT=180
